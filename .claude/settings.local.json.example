{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "model": "claude-opus-4-7",

  "permissions": {
    "allow": [
      "Bash(openocd *)",
      "Bash(gdb *)"
    ]
  },

  "enabledMcpjsonServers": ["github", "sentry", "postgres"],

  "env": {
    "MY_LOCAL_API_KEY": "replace-with-your-dev-key"
  }
}
