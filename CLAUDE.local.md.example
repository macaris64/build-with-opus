<!-- Example: local cFS headers installed outside the submodule path -->
<!-- - My cFS headers are at /opt/cfs/cfe/fsw/inc rather than the default submodule location -->

<!-- Example: local ROS 2 domain to avoid collision with lab hardware -->
<!-- - My ROS_DOMAIN_ID is 5 (lab hardware uses domain 0) -->

